<?xml version="1.0"?>

<robot name="rccar_bronco" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find rccar_description)/models/common_properties.xacro" />
  <xacro:include filename="$(find realsense2_description)/urdf/_d435i.urdf.xacro" />
  <xacro:include filename="$(find rccar_description)/models/rccar-bronco/rccar-bronco.gazebo.urdf.xacro" />
  <xacro:include filename="$(find rccar_description)/urdf/mid360.xacro" />

  <xacro:property name="wheel_diameter" value="0.110" />
  <xacro:property name="wheel_thickness" value="0.040" />

  <link name="base_link">
    <visual>
      <origin xyz="0.0 0.0 0.145" rpy="0 0 0" />
      <geometry>
        <box size="0.420 0.180 0.090" />
      </geometry>
      <material name="grey"/>
    </visual>
    <visual>
      <origin xyz="-0.080 0.0 0.225" rpy="0 0 0" />
      <geometry>
        <box size="0.260 0.180 0.070" />
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="-0.210 -0.090 0.110" rpy="0 0 0" />
      <geometry>
        <box size="0.420 0.180 0.160" />
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5" />
      <xacro:common_box_inertia m="1.5" x="0.420" y="0.180" z="0.160" />
    </inertial>
  </link>

  <link name="gps_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
      <geometry>
        <box size="0.055 0.060 0.0225" />
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="base_link_to_gps_link" type="fixed">
    <parent link="base_link"/>
    <child link="gps_link" />
    <origin xyz="0.151 0.0 0.152" rpy="0 0 0"/>
  </joint>

  <xacro:sensor_d435i parent="base_link" use_nominal_extrinsics="true" use_mesh="false">
    <origin xyz="-0.0239 0.0 0.279" rpy="0 0 0"/>
  </xacro:sensor_d435i>

  <xacro:mid360 name="lidar_link" parent="base_link" topic="lidar/points_raw">
    <origin xyz="-0.094 0.0 0.309" rpy="0 0 0"/>
  </xacro:mid360>

  <xacro:macro name="wheel" params="prefix suffix x y z mode">
    <link name="${prefix}_${suffix}_mount">
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
        <geometry>
          <cylinder radius="${wheel_diameter/2}" length="0.01"/>
        </geometry>
        <material name="grey" />
      </visual>
      <collision>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
        <geometry>
          <cylinder radius="${wheel_diameter/2}" length="0.01" />
        </geometry>
      </collision>
      <inertial>
        <mass value="8.0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint name="${prefix}_${suffix}_mount_joint" type="${mode}">
      <parent link="base_link" />
      <child link="${prefix}_${suffix}_mount" />
      <axis xyz="0 0 1" rpy="0 0 0" />
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0" />
      <!--<dynamics damping="0.0" friction="0.01" />-->
      <limit lower="-0.6458" upper="0.6458" effort="4.2" velocity="6.28" />
      <!--<limit lower="-0.6458" upper="0.6458" effort="0.5" velocity="6.28" />-->
    </joint>

    <link name="${prefix}_${suffix}_wheel">
      <visual>
        <origin xyz="0.0 0.0 0.0" rpy="${M_PI/2} 0 0" />
        <geometry>
          <cylinder radius="${wheel_diameter/2}" length="${wheel_thickness}" />
        </geometry>
        <material name="darkgrey" />
      </visual>
      <collision>
          <origin xyz="0.0 0.0 0.0" rpy="${M_PI/2} 0 0" />
          <geometry>
            <cylinder radius="${wheel_diameter/2}" length="${wheel_thickness}"/>
          </geometry>
      </collision>
      <inertial>
        <mass value="0.5" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
      <!--
      <inertial>
        <mass value="0.1" />
        <xacro:common_cylinder_inertia m="0.1" r="${wheel_diameter/2}" h="${wheel_thickness}" />
      </inertial>
      -->
    </link>

    <joint name="${prefix}_${suffix}_wheel_joint" type="continuous">
      <parent link="${prefix}_${suffix}_mount"/>
      <child link="${prefix}_${suffix}_wheel"/>
      <axis xyz="0 1 0" rpy="0 0 0" />
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <!--<dynamics damping="0.0" friction="0.01" />-->
    </joint>

    <gazebo reference="${prefix}_${suffix}_mount">
      <material>Gazebo/Grey</material>
    </gazebo>
    <gazebo reference="${prefix}_${suffix}_wheel">
      <material>Gazebo/DarkGrey</material>
    </gazebo>
  </xacro:macro>

  <!--
  <xacro:wheel prefix="front" suffix="left" x="0.123" y="0.126" z="${wheel_diameter/2}" mode="continuous" />
  <xacro:wheel prefix="front" suffix="right" x="0.123" y="-0.126" z="${wheel_diameter/2}" mode="continuous" />
  -->
  <xacro:wheel prefix="front" suffix="left" x="0.123" y="0.126" z="${wheel_diameter/2}" mode="revolute" />
  <xacro:wheel prefix="front" suffix="right" x="0.123" y="-0.126" z="${wheel_diameter/2}" mode="revolute" />
  <xacro:wheel prefix="rear" suffix="left" x="-0.133" y="0.126" z="${wheel_diameter/2}" mode="fixed" />
  <xacro:wheel prefix="rear" suffix="right" x="-0.133" y="-0.126" z="${wheel_diameter/2}" mode="fixed" />

</robot>
