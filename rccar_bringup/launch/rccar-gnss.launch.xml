<!-- rccar-gnss-only.launch.xml -->

<launch>
  <arg name="use_sim_time" default="false"/>
  <arg name="gnss_only" default="false"/>

  <group unless="$(var use_sim_time)">
    <include file="$(find-pkg-share rccar_bringup)/launch/rccar-ublox-gps-node.launch.py" />
  </group>

  <group if="$(var gnss_only)">
    <node pkg="tf2_ros" exec="static_transform_publisher" name="odom_to_base_link" args="0 0 0 0 0 0 odom base_link">
      <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node>

    <node pkg="initial_odometry" exec="initial_odometry" name="initial_odometry_node" output="both">
      <param from="$(find-pkg-share rccar_bringup)/config/rccar_initial_odom.yaml"/>
      <param name="use_sim_time" value="$(var use_sim_time)"/>
      <remap from="odometry/initial" to="odometry/local"/>
    </node>
  </group>

  <node pkg="navsatfix_conditional_relay" exec="navsatfix_conditional_relay" name="navsatfix_conditional_relay_node" output="both">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="relay_threshold" value="2"/>
    <param name="enable_status_override" value="$(var use_sim_time)"/>
    <param name="override_status" value="2"/>
    <remap from="gnss/in" to="gnss/fix_raw"/>
    <remap from="gnss/out" to="gnss/fix"/>
  </node>
</launch>

<!-- Memo -->
