<!-- rccar-simulation.launch.xml -->

<launch>
  <arg name="use_sim_time" default="true"/>
  <arg name="gnss_only" default="false"/>
  <arg name="use_gnss" default="true"/>
  <arg name="use_camera" default="true"/>
  <arg name="use_lidar" default="true"/>
  <!-- <arg name="world" default="empty.world"/> -->
  <arg name="world" default="smalltown.world"/>
  <!-- <arg name="model" default="$(find-pkg-share rccar_description)/models/rccar-unimog/rccar-unimog.urdf.xacro"/> -->
  <arg name="model" default="$(find-pkg-share rccar_description)/models/rccar-bronco/rccar-bronco.urdf.xacro"/>

  <include file="$(find-pkg-share rccar_gazebo)/launch/rccar-gazebo.launch.py">
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
    <arg name="world" value="$(var world)"/>
    <arg name="model" value="$(var model)"/>
  </include>

  <group if="$(var use_gnss)">
    <include file="$(find-pkg-share rccar_bringup)/launch/rccar-gnss.launch.xml">
      <arg name="use_sim_time" value="$(var use_sim_time)"/>
      <arg name="gnss_only" value="$(var gnss_only)"/>
    </include>
  </group>

  <group if="$(var use_camera)">
    <include file="$(find-pkg-share rccar_bringup)/launch/rccar-camera.launch.xml">
      <arg name="use_sim_time" value="$(var use_sim_time)"/>
    </include>
  </group>

  <group if="$(var use_lidar)">
    <include file="$(find-pkg-share rccar_bringup)/launch/rccar-lidar.launch.xml">
      <arg name="use_sim_time" value="$(var use_sim_time)"/>
    </include>
  </group>
</launch>
