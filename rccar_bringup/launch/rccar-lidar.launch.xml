<!-- rccar-lidar.launch.xml -->

<launch>
  <arg name="use_sim_time" default="false"/>

  <group unless="$(var use_sim_time)">
    <include file="$(find-pkg-share rccar_bringup)/launch/rccar-mid360.launch.py" />
  </group>

  <node pkg="imu_filter_madgwick" exec="imu_filter_madgwick_node" name="rccar_lidar_imu_filter_madgwick_node" output="both">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="use_mag" value="false"/>
    <param name="publish_tf" value="false"/>
    <param name="fixed_frame" value="livox_frame"/>
    <param name="world_frame" value="enu"/>
    <remap from="imu/data_raw" to="lidar/imu_raw"/>
    <remap from="imu/data" to="lidar/imu_filter"/>
  </node>

  <node pkg="imu_orientation_corrector" exec="imu_orientation_corrector" name="rccar_lidar_imu_corrector_node" output="both">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="base_frame" value="base_link"/>
    <param name="imu_frame" value="livox_frame"/>
    <param name="use_average_calibration" value="true"/>
    <param name="collection_duration_sec" value="5.0"/>
    <remap from="imu" to="lidar/imu_filter"/>
    <remap from="imu_corrected" to="lidar/imu"/>
  </node>

  <node pkg="pointcloud_to_laserscan" exec="pointcloud_to_laserscan_node" name="rccar_lidar_pointcloud_to_laserscan_node" output="both">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param from="$(find-pkg-share rccar_bringup)/config/rccar_lidar_pcl2scan_params.yaml"/>
    <remap from="cloud_in" to="lidar/points_raw_PointCloud2"/>
    <remap from="scan" to="lidar/scan/cloud"/>
  </node>
</launch>
