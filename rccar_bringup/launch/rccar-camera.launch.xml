<!-- rccar-camera.launch.xml -->

<launch>
  <arg name="use_sim_time" default="false"/>

  <group unless="$(var use_sim_time)">
    <include file="$(find-pkg-share rccar_bringup)/launch/rccar-rs-d435i.launch.py" />
  </group>

  <node pkg="imu_filter_madgwick" exec="imu_filter_madgwick_node" name="rccar_camera_imu_filter_madgwick_node" output="both">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="use_mag" value="false"/>
    <param name="publish_tf" value="false"/>
    <param name="fixed_frame" value="camera_gyro_optical_frame"/>
    <param name="world_frame" value="enu"/>
    <remap from="imu/data_raw" to="camera/imu_raw"/>
    <remap from="imu/data" to="camera/imu"/>
  </node>

  <node pkg="pointcloud_to_laserscan" exec="pointcloud_to_laserscan_node" name="rccar_camera_pointcloud_to_laserscan_node" output="both">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param from="$(find-pkg-share rccar_bringup)/config/rccar_camera_pcl2scan_params.yaml"/>
    <remap from="cloud_in" to="camera/depth/color/points"/>
    <remap from="scan" to="camera/scan/cloud"/>
  </node>

  <node pkg="depthimage_to_laserscan" exec="depthimage_to_laserscan_node" name="rccar_camera_depthimage_to_laserscan_node" output="both">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="scan_time" value="0.033"/>
    <param name="range_min" value="0.3"/>
    <param name="range_max" value="10.0"/>
    <param name="scan_height" value="1"/>
    <param name="output_frame" value="camera_depth_frame"/>
    <remap from="depth" to="camera/depth/image_rect_raw"/>
    <remap from="depth_camera_info" to="camera/depth/camera_info"/>
    <remap from="scan" to="camera/scan/depth"/>
  </node>

  <!-- todo : depthimage_to_laserscan_composed-launch.py -->

</launch>
