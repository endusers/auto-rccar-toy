<!-- odometry-filter.xml -->

<launch>
  <arg name="use_sim_time" default="false"/>

  <node pkg="odometry_filter" exec="odometry_filter" name="odometry_filter_node" output="both">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="map_frame" value="map"/>
    <param name="odom_frame" value="odom"/>
    <param name="base_link_frame" value="base_link"/>
    <param name="twist_publish_rate" value="1.0"/>
    <param name="initial_pose" value="[0.0, 0.0, 0.0]"/>
    <param name="update_yaw_only" value="false"/>
    <param name="publish_tf" value="false"/>
    <remap from="odom/in" to="odometry_raw"/>
    <remap from="odom/out" to="odometry"/>
    <remap from="initialpose" to="initialpose"/>
  </node>
</launch>

